# Database (GCP Cloud SQL PostgreSQL)
DATABASE_URL="postgresql://postgres:PASSWORD@GCP_PUBLIC_IP:5432/gta_crm?sslmode=require"
DIRECT_URL="postgresql://postgres:PASSWORD@GCP_PUBLIC_IP:5432/gta_crm?sslmode=require"

# Authentication
JWT_SECRET="your-secure-random-secret-key-here"

# App
NEXT_PUBLIC_APP_NAME="FLYVENTO CRM"

# Google Calendar + Meet Integration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# Zoho Meeting Integration
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REDIRECT_URI=https://your-domain.com/api/auth/zoho/callback
ZOHO_DOMAIN=zoho.com
